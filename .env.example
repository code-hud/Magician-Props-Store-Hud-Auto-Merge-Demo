# Database Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=magician_props_store

# Backend Configuration
NODE_ENV=development
PORT=3001

# Kafka (Redpanda) — unset KAFKA_BROKERS to disable order-events pipeline
KAFKA_BROKERS=redpanda:9092

# Hud monitoring
HUD_API_KEY=your_hud_api_key

# Git commit tag for Hud sessions (derived automatically by Makefile / START.sh)
# GIT_COMMIT_SHA=abc1234

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3001
